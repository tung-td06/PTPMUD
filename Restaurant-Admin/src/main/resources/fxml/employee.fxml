<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="main-bg" stylesheets="@../css/employee.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="employee.EmployeeController">
    <children>
        <VBox spacing="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">
            
            <!-- TOP BAR -->
            <HBox alignment="TOP_CENTER" spacing="14" styleClass="topbar">
                <VBox spacing="3">
                    <Label styleClass="dashboard-title" text="Nhân viên" />
                    <Label styleClass="dashboard-subtitle" text="Quản lí nhân viên" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <ComboBox fx:id="filterCombo" prefWidth="150" promptText="Vai trò" styleClass="search-box" />
                    <DatePicker fx:id="fromDate" prefWidth="130" promptText="Từ ngày" styleClass="date-picker-box" />
                    <DatePicker fx:id="toDate" prefWidth="130" promptText="Đến ngày" styleClass="date-picker-box" />
                    <TextField fx:id="searchField" prefWidth="280" promptText="Tìm kiếm nhân viên..." styleClass="search-box" />
                </HBox>
            </HBox>

            <!-- STATS CARDS -->
            <HBox spacing="16" VBox.vgrow="SOMETIMES">
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="👥 Tổng nhân sự" />
                    <Label fx:id="totalLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Tất cả các bộ phận" />
                </VBox>

                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🟢 Đang làm việc" />
                    <Label fx:id="activeLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Đang trong ca trực" />
                </VBox>

                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🔴 Đang nghỉ" />
                    <Label fx:id="offLabel" styleClass="card-value" text="0" />
                    <Label styleClass="warning-text" text="Có lịch trực sau" />
                </VBox>
            </HBox>

            <!-- TABLE WRAPPER -->
            <VBox spacing="14" styleClass="table-wrapper" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label styleClass="table-title" text="Danh sách nhân viên" />
                        <Label styleClass="table-subtitle" text="Chi tiết danh sách nhân viên trong hệ thống" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Button fx:id="createBtn" onAction="#handleAddNew" styleClass="create-btn" text="+ Thêm nhân viên" />
                        <Button fx:id="editBtn" onAction="#handleEdit" styleClass="edit-btn" text="📝 Sửa" />
                        <Button fx:id="deleteBtn" onAction="#handleDelete" styleClass="delete-btn" text="Xóa" />
                    </HBox>
                </HBox>

                <TableView fx:id="employeeTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="idColumn" minWidth="90" prefWidth="100" text="Mã NV" />
                        <TableColumn fx:id="nameColumn" minWidth="180" prefWidth="220" text="Họ và tên" />
                        <TableColumn fx:id="roleColumn" minWidth="120" prefWidth="150" text="Chức vụ" />
                        <TableColumn fx:id="phoneColumn" minWidth="130" prefWidth="160" text="Số điện thoại" />
                        <TableColumn fx:id="shiftColumn" minWidth="110" prefWidth="140" text="Ca trực" />
                        <TableColumn fx:id="statusColumn" minWidth="150" prefWidth="180" text="Trạng thái" />
                        <TableColumn fx:id="ngaySinhColumn" minWidth="110" prefWidth="130" text="Ngày sinh" />
                        <TableColumn fx:id="queColumn" minWidth="120" prefWidth="150" text="Quê quán" />
                        <TableColumn fx:id="gmailColumn" minWidth="160" prefWidth="190" text="Gmail" />
                        <TableColumn fx:id="noteColumn" minWidth="150" prefWidth="180" text="Ghi chú" />
                    </columns>
                </TableView>
            </VBox>
            
        </VBox>
    </children>
</AnchorPane>

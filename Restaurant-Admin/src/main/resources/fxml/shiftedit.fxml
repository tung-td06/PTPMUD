<?xml version="1.0" encoding="UTF-8"?>
 
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
 
<AnchorPane styleClass="add-bg" stylesheets="@../css/add.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="shift.ShiftEditController">
    <children>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <content>
                <VBox spacing="20">
                    <padding>
                        <Insets bottom="24" left="24" right="24" top="24" />
                    </padding>
 
                    <!-- HEADER -->
                    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="add-header">
                        <VBox spacing="3">
                            <Label styleClass="add-title" text="Sửa phân ca làm việc" />
                            <Label styleClass="add-subtitle" text="Cập nhật lịch làm việc trực tiếp cho nhân sự nhà hàng" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="backBtn" onAction="#handleBack" styleClass="back-btn" text="← Quay lại" />
                    </HBox>
 
                    <!-- FORM CARD -->
                    <VBox spacing="20" styleClass="form-card">
 
                        <!-- Section: Thông tin phân ca -->
                        <VBox spacing="4">
                            <Label styleClass="form-section-title" text="⏰ Thông tin ca trực" />
                            <Label styleClass="form-section-subtitle" text="Cập nhật các thông số lịch trực của nhân viên (*)" />
                        </VBox>
 
                        <GridPane hgap="20" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                            </columnConstraints>
 
                            <!-- Row 0 -->
                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox spacing="2"><Label styleClass="field-label" text="Mã ca trực (Không thể sửa)" /><Label styleClass="field-required" text="*" /></HBox>
                                <TextField fx:id="txtMaCa" editable="false" styleClass="form-field" style="-fx-opacity: 0.7; -fx-background-color: #e2e8f0;" />
                            </VBox>
                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <HBox spacing="2"><Label styleClass="field-label" text="Chọn nhân viên" /><Label styleClass="field-required" text="*" /></HBox>
                                <ComboBox fx:id="cbNhanVien" maxWidth="9999" promptText="Chọn nhân viên đăng ký" styleClass="form-combo" />
                            </VBox>
 
                            <!-- Row 1 -->
                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <HBox spacing="2"><Label styleClass="field-label" text="Tên ca trực" /><Label styleClass="field-required" text="*" /></HBox>
                                <TextField fx:id="txtTenCa" promptText="VD: Ca sáng, Ca chiều, Ca tối" styleClass="form-field" />
                            </VBox>
                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <HBox spacing="2"><Label styleClass="field-label" text="Thời gian bắt đầu" /><Label styleClass="field-required" text="*" /></HBox>
                                <TextField fx:id="txtGioBatDau" promptText="VD: 2026-06-14 06:00:00" styleClass="form-field" />
                            </VBox>
 
                            <!-- Row 2 -->
                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                <HBox spacing="2"><Label styleClass="field-label" text="Thời gian kết thúc" /><Label styleClass="field-required" text="*" /></HBox>
                                <TextField fx:id="txtGioKetThuc" promptText="VD: 2026-06-14 12:00:00" styleClass="form-field" />
                            </VBox>
                        </GridPane>
 
                        <!-- Message -->
                        <Label fx:id="lblMessage" styleClass="message-label" wrapText="true" />
 
                        <!-- Buttons -->
                        <HBox alignment="CENTER_RIGHT" spacing="12">
                            <Button fx:id="cancelBtn" onAction="#handleCancel" styleClass="cancel-btn" text="Hủy bỏ" />
                            <Button fx:id="saveBtn" onAction="#handleSave" styleClass="save-btn" text="💾 Cập nhật ca" />
                        </HBox>
                    </VBox>
 
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>

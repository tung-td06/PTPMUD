<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="main-bg" stylesheets="@../css/warehouse.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="warehouse.WarehouseController">
    <children>
        <VBox spacing="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">
            
            <!-- TOP BAR -->
            <HBox alignment="TOP_CENTER" spacing="14" styleClass="topbar">
                <VBox spacing="3">
                    <Label styleClass="dashboard-title" text="Kho nguyên liệu" />
                    <Label styleClass="dashboard-subtitle" text="Quản lý kho" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <TextField fx:id="searchField" prefWidth="280" promptText="Tìm nguyên liệu..." styleClass="search-box" />
                </HBox>
            </HBox>

            <!-- STATS CARDS -->
            <HBox spacing="16" VBox.vgrow="SOMETIMES">
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="📦 Tổng mặt hàng" />
                    <Label fx:id="totalItemsLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Tất cả nguyên liệu" />
                </VBox>

                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🟢 Đủ lượng tồn" />
                    <Label fx:id="sufficientLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="An toàn phục vụ" />
                </VBox>

                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🔴 Cần nhập gấp" />
                    <Label fx:id="warningLabel" styleClass="card-value" text="0" />
                    <Label styleClass="warning-text" text="Dưới định mức tối thiểu" />
                </VBox>
            </HBox>

            <!-- TABLE WRAPPER -->
            <VBox spacing="14" styleClass="table-wrapper" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label styleClass="table-title" text="Bảng kiểm kê kho hàng" />
                        <Label styleClass="table-subtitle" text="Số lượng tồn kho chi tiết và định mức an toàn" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Button fx:id="createBtn" onAction="#handleAddNew" styleClass="create-btn" text="+ Nhập kho" />
                        <Button fx:id="editBtn" onAction="#handleEdit" styleClass="edit-btn" text="📝 Sửa" />
                        <Button fx:id="deleteBtn" onAction="#handleDelete" styleClass="delete-btn" text="Xóa" />
                    </HBox>
                </HBox>

                <TableView fx:id="warehouseTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="idColumn" minWidth="90" prefWidth="100" text="Mã NL" />
                        <TableColumn fx:id="nameColumn" minWidth="200" prefWidth="250" text="Tên nguyên liệu" />
                        <TableColumn fx:id="unitColumn" minWidth="90" prefWidth="100" text="Đơn vị" />
                        <TableColumn fx:id="quantityColumn" minWidth="120" prefWidth="140" text="Số lượng tồn" />
                        <TableColumn fx:id="minQuantityColumn" minWidth="120" prefWidth="140" text="Tối thiểu" />
                        <TableColumn fx:id="statusColumn" minWidth="150" prefWidth="180" text="Tình trạng" />
                    </columns>
                </TableView>
            </VBox>
            
        </VBox>
    </children>
</AnchorPane>

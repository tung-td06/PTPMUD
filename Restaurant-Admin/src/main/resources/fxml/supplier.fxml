<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="main-bg" stylesheets="@../css/supplier.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="supplier.SupplierController">
    <children>
        <VBox spacing="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">
            
            <!-- TOP BAR -->
            <HBox alignment="TOP_CENTER" spacing="14" styleClass="topbar">
                <VBox spacing="3">
                    <Label styleClass="dashboard-title" text="Nhà cung cấp" />
                    <Label styleClass="dashboard-subtitle" text="Quản lý danh sách nhà cung cấp" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <TextField fx:id="searchField" prefWidth="280" promptText="Tìm kiếm nhà cung cấp..." styleClass="search-box" />
                </HBox>
            </HBox>

            <!-- STATS CARDS -->
            <HBox spacing="16" VBox.vgrow="SOMETIMES">
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🏢 Tổng nhà cung cấp" />
                    <Label fx:id="totalLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Đang hoạt động" />
                </VBox>
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="📞 Kênh liên lạc" />
                    <Label styleClass="card-value" text="Hotline" />
                    <Label styleClass="success-text" text="Tất cả có số điện thoại" />
                </VBox>
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🤝 Trạng thái hợp tác" />
                    <Label styleClass="card-value" text="Đồng bộ" />
                    <Label styleClass="warning-text" text="Theo dõi nhập hàng" />
                </VBox>
            </HBox>

            <!-- TABLE WRAPPER -->
            <VBox spacing="14" styleClass="table-wrapper" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label styleClass="table-title" text="Danh sách nhà cung cấp" />
                        <Label styleClass="table-subtitle" text="Chi tiết danh sách đối tác nhà cung cấp" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Button fx:id="createBtn" onAction="#handleAddNew" styleClass="create-btn" text="+ Thêm nhà cung cấp" />
                        <Button fx:id="editBtn" onAction="#handleEdit" styleClass="edit-btn" text="📝 Sửa" />
                        <Button fx:id="deleteBtn" onAction="#handleDelete" styleClass="delete-btn" text="Xóa" />
                    </HBox>
                </HBox>

                <TableView fx:id="supplierTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="manccColumn" minWidth="120" prefWidth="150" text="Mã NCC" />
                        <TableColumn fx:id="tennccColumn" minWidth="250" prefWidth="350" text="Tên nhà cung cấp" />
                        <TableColumn fx:id="sdtColumn" minWidth="150" prefWidth="200" text="Số điện thoại" />
                    </columns>
                </TableView>
            </VBox>
            
        </VBox>
    </children>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="main-bg" stylesheets="@../css/food.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="food.FoodController">
    <children>
        <VBox spacing="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">
            
            <!-- TOP BAR -->
            <HBox alignment="TOP_CENTER" spacing="14" styleClass="topbar">
                <VBox spacing="3">
                    <Label styleClass="dashboard-title" text="Món ăn" />
                    <Label styleClass="dashboard-subtitle" text="Quản lí món ăn" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <ComboBox fx:id="filterCombo" prefWidth="150" promptText="Danh mục" styleClass="search-box" />
                    <TextField fx:id="searchField" prefWidth="280" promptText="Tìm mã món, tên món..." styleClass="search-box" />
                </HBox>
            </HBox>

            <!-- STATS CARDS -->
            <HBox spacing="16" VBox.vgrow="SOMETIMES">
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🍜 Tổng số món ăn" />
                    <Label fx:id="totalLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Tất cả danh mục" />
                </VBox>

                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🟢 Còn món" />
                    <Label fx:id="activeLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Sẵn sàng phục vụ" />
                </VBox>

                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🔴 Hết món" />
                    <Label fx:id="outLabel" styleClass="card-value" text="0" />
                    <Label styleClass="warning-text" text="Đợi nhập nguyên liệu" />
                </VBox>
            </HBox>

            <!-- TABLE WRAPPER WITH FILTERS -->
            <VBox spacing="14" styleClass="table-wrapper" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label styleClass="table-title" text="Danh sách thực đơn" />
                        <Label styleClass="table-subtitle" text="Chi tiết các món ăn theo danh mục và trạng thái" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Button fx:id="createBtn" onAction="#handleAddNew" styleClass="create-btn" text="+ Thêm món mới" />
                        <Button fx:id="editBtn" onAction="#handleEdit" styleClass="edit-btn" text="📝 Sửa" />
                        <Button fx:id="deleteBtn" onAction="#handleDelete" styleClass="delete-btn" text="Xóa" />
                    </HBox>
                </HBox>


                <TableView fx:id="foodTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="idColumn" minWidth="90" prefWidth="100" text="Mã món" />
                        <TableColumn fx:id="nameColumn" minWidth="200" prefWidth="250" text="Tên món ăn" />
                        <TableColumn fx:id="categoryColumn" minWidth="120" prefWidth="150" text="Danh mục" />
                        <TableColumn fx:id="priceColumn" minWidth="140" prefWidth="180" text="Đơn giá" />
                        <TableColumn fx:id="statusColumn" minWidth="150" prefWidth="180" text="Trạng thái" />
                    </columns>
                </TableView>
            </VBox>
            
        </VBox>
    </children>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="main-bg" stylesheets="@../css/shift.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="shift.ShiftController">
    <children>
        <VBox spacing="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">
            
            <!-- TOP BAR -->
            <HBox alignment="TOP_CENTER" spacing="14" styleClass="topbar">
                <VBox spacing="3">
                    <Label styleClass="dashboard-title" text="Ca làm việc" />
                    <Label styleClass="dashboard-subtitle" text="Quản lý việc của nhân sự" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <ComboBox fx:id="filterCombo" prefWidth="150" promptText="Ca làm" styleClass="search-box" />
                    <DatePicker fx:id="fromDate" prefWidth="130" promptText="Từ ngày" styleClass="date-picker-box" />
                    <DatePicker fx:id="toDate" prefWidth="130" promptText="Đến ngày" styleClass="date-picker-box" />
                    <TextField fx:id="searchField" prefWidth="280" promptText="Tìm kiếm ca làm..." styleClass="search-box" />
                </HBox>
            </HBox>

            <!-- STATS CARDS -->
            <HBox spacing="16" VBox.vgrow="SOMETIMES">
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="⏰ Tổng ca làm việc" />
                    <Label fx:id="totalLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Đã phân lịch" />
                </VBox>
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="📅 Lịch tuần này" />
                    <Label styleClass="card-value" text="Ổn định" />
                    <Label styleClass="success-text" text="Đã duyệt ca làm" />
                </VBox>
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="👥 Nhân sự trực" />
                    <Label styleClass="card-value" text="Đầy đủ" />
                    <Label styleClass="warning-text" text="Theo đúng phân công" />
                </VBox>
            </HBox>

            <!-- TABLE WRAPPER -->
            <VBox spacing="14" styleClass="table-wrapper" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label styleClass="table-title" text="Danh sách phân ca làm việc" />
                        <Label styleClass="table-subtitle" text="Thông tin lịch trực chi tiết của nhân sự" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Button fx:id="createBtn" onAction="#handleAddNew" styleClass="create-btn" text="+ Phân ca làm việc" />
                        <Button fx:id="editBtn" onAction="#handleEdit" styleClass="edit-btn" text="📝 Sửa" />
                        <Button fx:id="deleteBtn" onAction="#handleDelete" styleClass="delete-btn" text="Xóa" />
                    </HBox>
                </HBox>

                <TableView fx:id="shiftTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="macaColumn" minWidth="90" prefWidth="110" text="Mã ca" />
                        <TableColumn fx:id="manvColumn" minWidth="100" prefWidth="130" text="Mã nhân viên" />
                        <TableColumn fx:id="tencaColumn" minWidth="120" prefWidth="150" text="Tên ca trực" />
                        <TableColumn fx:id="giobatdauColumn" minWidth="150" prefWidth="180" text="Giờ bắt đầu" />
                        <TableColumn fx:id="gioketthucColumn" minWidth="150" prefWidth="180" text="Giờ kết thúc" />
                    </columns>
                </TableView>
            </VBox>
            
        </VBox>
    </children>
</AnchorPane>

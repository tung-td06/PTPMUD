<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="main-bg" stylesheets="@../css/table.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="table.TableController">
    <children>
        <VBox spacing="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">
            
            <!-- TOP BAR -->
            <HBox alignment="TOP_CENTER" spacing="14" styleClass="topbar">
                <VBox spacing="3">
                    <Label styleClass="dashboard-title" text="Bàn ăn" />
                    <Label styleClass="dashboard-subtitle" text="Quản lý bàn ăn" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <DatePicker fx:id="dpFilterDate" prefWidth="150" promptText="Chọn ngày" styleClass="date-picker-box" />
                    <ComboBox fx:id="filterCombo" prefWidth="150" promptText="Tất cả" styleClass="search-box" />
                    <TextField fx:id="searchField" prefWidth="280" promptText="Tìm tên bàn, số người..." styleClass="search-box" />
                </HBox>
            </HBox>

            <!-- STATS CARDS -->
            <HBox spacing="16" VBox.vgrow="SOMETIMES">
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🍽 Tổng số bàn" />
                    <Label fx:id="totalLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Tất cả các khu vực" />
                </VBox>

                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🟢 Bàn trống" />
                    <Label fx:id="emptyLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Sẵn sàng đón khách" />
                </VBox>

                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🔴 Có khách" />
                    <Label fx:id="activeLabel" styleClass="card-value" text="0" />
                    <Label styleClass="warning-text" text="Đang phục vụ" />
                </VBox>

                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🟡 Đã đặt" />
                    <Label fx:id="reservedLabel" styleClass="card-value" text="0" />
                    <Label styleClass="warning-text" text="Đợi khách nhận bàn" />
                </VBox>
            </HBox>

            <!-- FILTER & GRID WRAPPER -->
            <VBox spacing="14" styleClass="table-wrapper" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label styleClass="table-title" text="Sơ đồ bàn ăn nhà hàng" />
                        <Label styleClass="table-subtitle" text="Trạng thái phục vụ các bàn theo thời gian thực" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Button fx:id="detailBtn" onAction="#handleDetail" styleClass="edit-btn" style="-fx-background-color: #10b981; -fx-text-fill: white;" text="👁 Xem chi tiết" />
                        <Button fx:id="createBtn" onAction="#handleAddNew" styleClass="create-btn" text="+ Thêm bàn mới" />
                        <Button fx:id="editBtn" onAction="#handleEdit" styleClass="edit-btn" text="📝 Sửa" />
                        <Button fx:id="deleteBtn" onAction="#handleDelete" styleClass="delete-btn" text="Xóa" />
                    </HBox>
                </HBox>
                <ScrollPane fx:id="tableScrollPane" styleClass="grid-scroll" VBox.vgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="tableFlowPane" hgap="20" vgap="20" styleClass="flow-grid">
                            <padding>
                                <Insets bottom="10" left="10" right="10" top="10" />
                            </padding>
                        </FlowPane>
                    </content>
                </ScrollPane>
            </VBox>
            
        </VBox>
    </children>
</AnchorPane>

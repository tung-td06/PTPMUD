<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="main-bg" stylesheets="@../css/recipe.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="recipe.RecipeController">
    <children>
        <VBox spacing="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">

            <!-- TOP BAR -->
            <HBox alignment="TOP_CENTER" spacing="14" styleClass="topbar">
                <VBox spacing="3">
                    <Label styleClass="dashboard-title" text="Định lượng món ăn" />
                    <Label styleClass="dashboard-subtitle" text="Quản lý nguyên vật liệu cho từng món" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <TextField fx:id="searchField" prefWidth="280" promptText="Tìm tên món, nguyên liệu..." styleClass="search-box" />
                </HBox>
            </HBox>

            <!-- STATS CARDS -->
            <HBox spacing="16" VBox.vgrow="SOMETIMES">
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🍲 Món ăn đã định lượng" />
                    <Label fx:id="totalRecipesLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Đã cấu hình công thức" />
                </VBox>
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🌾 Nguyên liệu sử dụng" />
                    <Label fx:id="totalIngredientsLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Các loại nguyên vật liệu" />
                </VBox>
            </HBox>

            <!-- TABLE WRAPPER -->
            <VBox spacing="14" styleClass="table-wrapper" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label styleClass="table-title" text="Danh sách định lượng món ăn" />
                        <Label styleClass="table-subtitle" text="Tỷ lệ định lượng nguyên liệu cho từng món ăn" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Button fx:id="viewDetailBtn" onAction="#handleViewDetail" styleClass="edit-btn" style="-fx-background-color: #10b981; -fx-text-fill: white;" text="👁 Xem chi tiết" />
                        <Button fx:id="createBtn" onAction="#handleAddNew" styleClass="create-btn" text="+ Thêm định lượng" />
                        <Button fx:id="editBtn" onAction="#handleEdit" styleClass="edit-btn" text="📝 Sửa" />
                        <Button fx:id="deleteBtn" onAction="#handleDelete" styleClass="delete-btn" text="Xóa" />
                    </HBox>
                </HBox>

                <TableView fx:id="recipeTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="mamonColumn" minWidth="80" prefWidth="120" text="Mã món" />
                        <TableColumn fx:id="tenmonColumn" minWidth="180" prefWidth="250" text="Tên món ăn" />
                        <TableColumn fx:id="manguyenlieuColumn" minWidth="120" prefWidth="180" text="Số nguyên liệu" />
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </children>
</AnchorPane>

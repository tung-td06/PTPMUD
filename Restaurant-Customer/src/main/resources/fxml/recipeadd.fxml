<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="add-bg" stylesheets="@../css/recipeadd.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="recipe.RecipeAddController">
    <children>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <content>
                <VBox spacing="20">
                    <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>

                    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="add-header">
                        <VBox spacing="3">
                            <Label styleClass="add-title" text="Thêm định lượng mới" />
                            <Label styleClass="add-subtitle" text="Định nghĩa tỷ lệ nguyên liệu chế biến món ăn" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="backBtn" onAction="#handleBack" styleClass="back-btn" text="← Quay lại" />
                    </HBox>

                    <VBox spacing="20" styleClass="form-card">
                        <VBox spacing="4">
                            <Label styleClass="form-section-title" text="🍲 Công thức &amp; Nguyên liệu" />
                            <Label styleClass="form-section-subtitle" text="Chọn món ăn và nguyên liệu chế biến tương ứng" />
                        </VBox>

                        <GridPane hgap="20" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                            </columnConstraints>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox spacing="2"><Label styleClass="field-label" text="Chọn Món ăn" /><Label styleClass="field-required" text="*" /></HBox>
                                <ComboBox fx:id="cbMonAn" maxWidth="9999" promptText="Chọn món ăn" styleClass="form-combo" />
                            </VBox>
                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <HBox spacing="2"><Label styleClass="field-label" text="Chọn Nguyên liệu" /><Label styleClass="field-required" text="*" /></HBox>
                                <ComboBox fx:id="cbNguyenLieu" maxWidth="9999" promptText="Chọn nguyên liệu" styleClass="form-combo" />
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <HBox spacing="2"><Label styleClass="field-label" text="Mã món ăn" /><Label styleClass="field-required" text="*" /></HBox>
                                <TextField fx:id="txtMamon" promptText="Mã món ăn" styleClass="form-field" />
                            </VBox>
                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <HBox spacing="2"><Label styleClass="field-label" text="Tên món ăn" /><Label styleClass="field-required" text="*" /></HBox>
                                <TextField fx:id="txtTenmon" promptText="Tên món ăn" styleClass="form-field" />
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                <HBox spacing="2"><Label styleClass="field-label" text="Mã nguyên liệu" /><Label styleClass="field-required" text="*" /></HBox>
                                <TextField fx:id="txtMaNguyenLieu" promptText="Mã nguyên liệu" styleClass="form-field" />
                            </VBox>
                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                <HBox spacing="2"><Label styleClass="field-label" text="Tên nguyên liệu" /><Label styleClass="field-required" text="*" /></HBox>
                                <TextField fx:id="txtTenNguyenLieu" promptText="Tên nguyên liệu" styleClass="form-field" />
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                <HBox spacing="2"><Label styleClass="field-label" text="Định lượng" /><Label styleClass="field-required" text="*" /></HBox>
                                <TextField fx:id="txtDinhLuong" promptText="VD: 150, 10, 2..." styleClass="form-field" />
                            </VBox>
                        </GridPane>

                        <Label fx:id="lblMessage" styleClass="message-label" wrapText="true" />

                        <HBox alignment="CENTER_RIGHT" spacing="12">
                            <Button fx:id="cancelBtn" onAction="#handleCancel" styleClass="cancel-btn" text="Hủy bỏ" />
                            <Button fx:id="saveBtn" onAction="#handleSave" styleClass="save-btn" text="💾 Lưu định lượng" />
                        </HBox>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>

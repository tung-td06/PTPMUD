<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" styleClass="main-bg" 
            stylesheets="@../../css/customer/common.css, @../../css/customer/component.css, @../../css/customer/customer_history.css" 
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="customer.controller.history.CustomerHistoryController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" 
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>
                <!-- Header -->
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="title-label" text="Lịch sử hoạt động" />
                                <Label styleClass="subtitle-label" text="Quản lý lịch sử hóa đơn thanh toán và đặt bàn" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <!-- Segment controller -->
                        <HBox styleClass="segment-button-container">
                            <children>
                                <Button fx:id="btnBills" onAction="#handleBillsSegment" styleClass="segment-button, segment-button-active" text="📄 Hóa đơn" />
                                <Button fx:id="btnBookings" onAction="#handleBookingsSegment" styleClass="segment-button" text="📅 Đặt bàn" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <!-- Filters -->
                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="menu-filter-bar">
                    <children>
                        <TextField fx:id="txtSearchCode" id="txtSearchCode" prefHeight="44.0" prefWidth="220.0" minWidth="220.0" promptText="Tìm mã hóa đơn..." />
                        <DatePicker fx:id="dpFilterDate" id="dpFilterDate" prefHeight="44.0" prefWidth="180.0" minWidth="180.0" promptText="Lọc theo ngày" />
                        <ComboBox fx:id="cmbFilterMonth" id="cmbFilterMonth" prefHeight="44.0" prefWidth="160.0" minWidth="160.0" promptText="Lọc theo tháng" styleClass="combobox-filter" />
                        <ComboBox fx:id="cmbFilterStatus" id="cmbFilterStatus" prefHeight="44.0" prefWidth="180.0" minWidth="180.0" promptText="Trạng thái" styleClass="combobox-filter" />
                    </children>
                </HBox>

                <!-- Container Scroll -->
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="historyContainer" spacing="15.0">
                            <padding>
                                <Insets right="5.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</AnchorPane>

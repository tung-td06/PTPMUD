<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="main-bg" stylesheets="@../css/customer.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="customer.CustomerController">
    <children>
        <VBox spacing="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">
            
<!-- TOP BAR -->
            <HBox alignment="TOP_CENTER" spacing="14" styleClass="topbar">
                <VBox spacing="3">
                    <Label styleClass="dashboard-title" text="Khách hàng" />
                    <Label styleClass="dashboard-subtitle" text="Quản lí khách hàng" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <TextField fx:id="searchField" prefWidth="280" promptText="Tìm tên, SĐT, email..." styleClass="search-box" />
                </HBox>
            </HBox>

            <!-- STATS CARDS -->
            <HBox spacing="16" VBox.vgrow="SOMETIMES">
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="👥 Tổng số khách" />
                    <Label fx:id="totalLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Đăng ký thành viên" />
                </VBox>

                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="⭐ Khách hàng VIP" />
                    <Label fx:id="vipLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Điểm tích lũy >= 100" />
                </VBox>

                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="📈 Tổng điểm thành viên" />
                    <Label fx:id="pointsLabel" styleClass="card-value" text="0" />
                    <Label styleClass="warning-text" text="Tích lũy toàn hệ thống" />
                </VBox>
            </HBox>

            <!-- TABLE WRAPPER -->
            <VBox spacing="14" styleClass="table-wrapper" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label styleClass="table-title" text="Danh sách khách hàng" />
                        <Label styleClass="table-subtitle" text="Chi tiết danh sách khách hàng thân thiết" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />

                </HBox>

                <TableView fx:id="customerTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="makhColumn" minWidth="100" prefWidth="120" text="Mã KH" />
                        <TableColumn fx:id="tenkhColumn" minWidth="200" prefWidth="250" text="Tên khách hàng" />
                        <TableColumn fx:id="sdtColumn" minWidth="150" prefWidth="180" text="Số điện thoại" />
                        <TableColumn fx:id="diemtichluyColumn" minWidth="150" prefWidth="180" text="Điểm tích lũy" />
                    </columns>
                </TableView>
            </VBox>
            
        </VBox>
    </children>
</AnchorPane>

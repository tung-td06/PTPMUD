<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="add-bg" stylesheets="@../css/billdetailadd.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="billdetail.BillDetailAddController">
    <children>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <content>
                <VBox spacing="20">
                    <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>

                    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="add-header">
                        <VBox spacing="3">
                            <Label styleClass="add-title" text="Thêm chi tiết hóa đơn" />
                            <Label styleClass="add-subtitle" text="Thêm mặt hàng vào hóa đơn" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="backBtn" onAction="#handleBack" styleClass="back-btn" text="← Quay lại" />
                    </HBox>

                    <VBox spacing="20" styleClass="form-card">
                        <VBox spacing="4">
                            <Label styleClass="form-section-title" text="📋 Thông tin chi tiết" />
                            <Label styleClass="form-section-subtitle" text="Chọn hóa đơn và món ăn để thêm chi tiết" />
                        </VBox>

                        <GridPane hgap="20" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                            </columnConstraints>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox spacing="2"><Label styleClass="field-label" text="Mã hóa đơn" /><Label styleClass="field-required" text="*" /></HBox>
                                <ComboBox fx:id="cbMaHD" maxWidth="9999" promptText="Chọn hóa đơn" styleClass="form-combo" />
                            </VBox>
                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <HBox spacing="2"><Label styleClass="field-label" text="Món ăn" /><Label styleClass="field-required" text="*" /></HBox>
                                <ComboBox fx:id="cbMonAn" maxWidth="9999" promptText="Chọn món ăn" styleClass="form-combo" />
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <HBox spacing="2"><Label styleClass="field-label" text="Số lượng" /><Label styleClass="field-required" text="*" /></HBox>
                                <TextField fx:id="txtSoluong" promptText="VD: 2" styleClass="form-field" />
                            </VBox>
                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label styleClass="field-label" text="Đơn giá (VNĐ)" />
                                <TextField fx:id="txtDongia" promptText="Tự động điền" styleClass="form-field" />
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                <Label styleClass="field-label" text="Thành tiền (VNĐ)" />
                                <TextField fx:id="txtThanhtien" editable="false" promptText="Tự động tính" styleClass="form-field" />
                            </VBox>
                        </GridPane>

                        <Label fx:id="lblMessage" styleClass="message-label" wrapText="true" />

                        <HBox alignment="CENTER_RIGHT" spacing="12">
                            <Button fx:id="cancelBtn" onAction="#handleCancel" styleClass="cancel-btn" text="Hủy bỏ" />
                            <Button fx:id="saveBtn" onAction="#handleSave" styleClass="save-btn" text="💾 Lưu chi tiết" />
                        </HBox>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>

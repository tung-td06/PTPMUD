<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="main-bg" stylesheets="@../css/booking.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="booking.BookingController">
    <children>
        <VBox spacing="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">
            
            <!-- TOP BAR -->
            <HBox alignment="TOP_CENTER" spacing="14" styleClass="topbar">
                <VBox spacing="3">
                    <Label styleClass="dashboard-title" text="Đặt bàn" />
                    <Label styleClass="dashboard-subtitle" text="Quản lí đặt bàn" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <ComboBox fx:id="filterCombo" prefWidth="150" promptText="Trạng thái" styleClass="search-box" />
                    <DatePicker fx:id="fromDate" prefWidth="130" promptText="Từ ngày" styleClass="date-picker-box" />
                    <DatePicker fx:id="toDate" prefWidth="130" promptText="Đến ngày" styleClass="date-picker-box" />
                    <TextField fx:id="searchField" prefWidth="280" promptText="Tìm tên khách, số điện thoại..." styleClass="search-box" />
                </HBox>
            </HBox>

            <!-- STATS CARDS -->
            <HBox spacing="16" VBox.vgrow="SOMETIMES">
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="📅 Tổng số lượt đặt" />
                    <Label fx:id="totalBookingsLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Tất cả thời gian" />
                </VBox>

                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🟢 Đã xác nhận" />
                    <Label fx:id="confirmedBookingsLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Đã chuẩn bị sẵn bàn" />
                </VBox>

                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🟠 Chờ xác nhận" />
                    <Label fx:id="pendingBookingsLabel" styleClass="card-value" text="0" />
                    <Label styleClass="warning-text" text="Đợi nhân viên duyệt" />
                </VBox>

                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🔴 Đã hủy" />
                    <Label fx:id="cancelledBookingsLabel" styleClass="card-value" text="0" />
                    <Label styleClass="warning-text" text="Khách hủy lịch" />
                </VBox>
            </HBox>

            <!-- TABLE WRAPPER -->
            <VBox spacing="14" styleClass="table-wrapper" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label styleClass="table-title" text="Sổ đặt bàn điện tử" />
                        <Label styleClass="table-subtitle" text="Danh sách khách đặt chỗ trước hôm nay và ngày mai" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Button fx:id="viewDetailBtn" onAction="#handleViewDetail" styleClass="edit-btn" style="-fx-background-color: #10b981; -fx-text-fill: white;" text="👁 Xem chi tiết" />
                        <Button fx:id="createBtn" onAction="#handleAddNew" styleClass="create-btn" text="+ Đặt bàn mới" />
                        <Button fx:id="editBtn" onAction="#handleEdit" styleClass="edit-btn" text="📝 Sửa" />
                        <Button fx:id="deleteBtn" onAction="#handleDelete" styleClass="delete-btn" text="Xóa" />
                    </HBox>
                </HBox>

                <TableView fx:id="bookingTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" minWidth="90" prefWidth="100" text="Mã đặt" />
                        <TableColumn fx:id="customerColumn" minWidth="150" prefWidth="180" text="Khách hàng" />
                        <TableColumn fx:id="tableColumn" minWidth="100" prefWidth="120" text="Bàn" />
                        <TableColumn fx:id="arrivalTimeColumn" minWidth="140" prefWidth="160" text="Thời gian đến" />
                        <TableColumn fx:id="timeColumn" minWidth="140" prefWidth="160" text="Thời gian vào" />
                        <TableColumn fx:id="timeRaColumn" minWidth="140" prefWidth="160" text="Thời gian ra" />
                        <TableColumn fx:id="guestsColumn" minWidth="90" prefWidth="100" text="Số người" />
                        <TableColumn fx:id="statusColumn" minWidth="150" prefWidth="180" text="Trạng thái" />
                        <TableColumn fx:id="noteColumn" minWidth="150" prefWidth="200" text="Ghi chú" />
                    </columns>
                </TableView>
            </VBox>
            
        </VBox>
    </children>
</AnchorPane>

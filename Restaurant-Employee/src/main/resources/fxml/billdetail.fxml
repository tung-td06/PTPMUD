<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="main-bg" stylesheets="@../css/billdetail.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="billdetail.BillDetailController">
    <children>
        <VBox spacing="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">

            <!-- TOP BAR -->
            <HBox alignment="TOP_CENTER" spacing="14" styleClass="topbar">
                <VBox spacing="3">
                    <Label styleClass="dashboard-title" text="Chi tiết hóa đơn" />
                    <Label fx:id="billSubtitleLabel" styleClass="dashboard-subtitle" text="Đang tải dữ liệu..." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <TextField fx:id="searchField" prefWidth="280" promptText="Tìm tên món, mã món..." styleClass="search-box" />
                </HBox>
            </HBox>

            <!-- STATS CARDS -->
            <HBox spacing="16" VBox.vgrow="SOMETIMES">
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="📋 Số món trong hóa đơn" />
                    <Label fx:id="totalLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Tổng số dòng chi tiết" />
                </VBox>
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="💰 Tổng thành tiền" />
                    <Label fx:id="totalAmountLabel" styleClass="card-value" text="0 VNĐ" />
                    <Label styleClass="success-text" text="Tổng giá trị hóa đơn" />
                </VBox>
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🧾 Mã hóa đơn" />
                    <Label fx:id="billIdLabel" styleClass="card-value" text="---" />
                    <Label styleClass="warning-text" text="Đang xem chi tiết" />
                </VBox>
            </HBox>

            <!-- TABLE WRAPPER -->
            <VBox spacing="14" styleClass="table-wrapper" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label styleClass="table-title" text="Danh sách món ăn trong hóa đơn" />
                        <Label fx:id="tableSubtitleLabel" styleClass="table-subtitle" text="Các món ăn thuộc hóa đơn đang xem" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Button fx:id="backBtn" onAction="#handleBack" styleClass="back-btn" text="← Quay lại" />
                    </HBox>
                </HBox>

                <TableView fx:id="billDetailTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="mamonColumn" minWidth="90" prefWidth="110" text="Mã món" />
                        <TableColumn fx:id="tenmonColumn" minWidth="200" prefWidth="300" text="Tên món ăn" />
                        <TableColumn fx:id="soluongColumn" minWidth="70" prefWidth="90" text="Số lượng" />
                        <TableColumn fx:id="dongiaColumn" minWidth="130" prefWidth="180" text="Đơn giá" />
                        <TableColumn fx:id="thanhtienColumn" minWidth="130" prefWidth="180" text="Thành tiền" />
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </children>
</AnchorPane>

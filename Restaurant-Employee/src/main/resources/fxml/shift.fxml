<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="main-bg" stylesheets="@../css/shift.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="shift.ShiftController">
    <children>
        <VBox spacing="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">
            
            <!-- TOP BAR / HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="topbar">
                <VBox spacing="3">
                    <Label styleClass="dashboard-title" text="Ca làm việc" />
                    <Label styleClass="dashboard-subtitle" text="Lịch trực chi tiết của tôi" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <ComboBox fx:id="statusCombo" prefWidth="150" promptText="Trạng thái" styleClass="search-box" />
                    <DatePicker fx:id="datePicker" prefWidth="130" promptText="Chọn ngày" styleClass="date-picker-box" />
                    <TextField fx:id="searchField" prefWidth="250" promptText="Tìm kiếm ca..." styleClass="search-box" />
                </HBox>
            </HBox>

            <!-- STATS CARDS -->
            <HBox spacing="16" VBox.vgrow="SOMETIMES">
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="⏰ Ca hôm nay" />
                    <Label fx:id="todayLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Lịch trực trong ngày" />
                </VBox>
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="📅 Ca tuần này" />
                    <Label fx:id="weekLabel" styleClass="card-value" text="0" />
                    <Label styleClass="success-text" text="Lịch trực trong tuần" />
                </VBox>
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="⏳ Tổng giờ làm tuần" />
                    <Label fx:id="weekHoursLabel" styleClass="card-value" text="0 giờ" />
                    <Label styleClass="warning-text" text="Tổng thời gian trực" />
                </VBox>
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="🔔 Ca tiếp theo" />
                    <Label fx:id="nextShiftLabel" styleClass="card-value" text="Không có" />
                    <Label styleClass="success-text" text="Lịch trực sắp tới" />
                </VBox>
            </HBox>

            <!-- TABLE WRAPPER -->
            <VBox spacing="14" styleClass="table-wrapper" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label styleClass="table-title" text="Danh sách ca làm việc của tôi" />
                        <Label styleClass="table-subtitle" text="Thông tin lịch trực chi tiết của bạn" />
                    </VBox>
                </HBox>

                <TableView fx:id="shiftTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="macaColumn" minWidth="90" prefWidth="110" text="Mã ca" />
                        <TableColumn fx:id="tencaColumn" minWidth="120" prefWidth="150" text="Tên ca" />
                        <TableColumn fx:id="ngaylamColumn" minWidth="110" prefWidth="130" text="Ngày làm" />
                        <TableColumn fx:id="giobatdauColumn" minWidth="110" prefWidth="130" text="Giờ bắt đầu" />
                        <TableColumn fx:id="gioketthucColumn" minWidth="110" prefWidth="130" text="Giờ kết thúc" />
                        <TableColumn fx:id="tongthogianColumn" minWidth="110" prefWidth="130" text="Tổng thời gian" />
                        <TableColumn fx:id="trangthaiColumn" minWidth="130" prefWidth="150" text="Trạng thái" />
                    </columns>
                </TableView>
            </VBox>
            
        </VBox>
    </children>
</AnchorPane>
